                             same_net_via_cells.append((gx + ex, gy + ey))
 
+    # Same-net SMD pad via clearance (opt-in): block the pad copper area (+ this
+    # clearance) as via sites so the router can't drop a via inside the net's own
+    # SMD pad (via-in-pad). The track can still terminate on the pad (only VIA
+    # placement is blocked), so the router arrives on the pad's layer or taps in
+    # from a via just outside the pad. Through-hole pads are handled above.
+    if config.same_net_pad_via_clearance >= 0:
+        margin = config.via_size / 2 + config.same_net_pad_via_clearance + config.grid_step / 2
+        for pad in pcb_data.pads_by_net.get(net_id, []):
+            if pad.drill and pad.drill > 0:
+                continue
+            half_w, half_h = pad.size_x / 2, pad.size_y / 2
+            if pad.shape in ('circle', 'oval'):
+                corner_radius = min(half_w, half_h)
+            elif pad.shape == 'roundrect':
+                corner_radius = pad.roundrect_rratio * min(pad.size_x, pad.size_y)
+            else:
+                corner_radius = 0.0
+            gx, gy = coord.to_grid(pad.global_x, pad.global_y)
+            for cell in iter_pad_blocked_cells(
+                    gx, gy, half_w, half_h, margin, config.grid_step, corner_radius,
+                    off_x=pad.global_x - gx * coord.grid_step,
+                    off_y=pad.global_y - gy * coord.grid_step,
+                    rotation_deg=pad.rect_rotation):
+                same_net_via_cells.append(cell)
+
